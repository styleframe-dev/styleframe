{
	"version": 1,
	"hooks": {
		"postToolUse": [
			{
				"command": "caliber learn observe"
			}
		],
		"postToolUseFailure": [
			{
				"command": "caliber learn observe --failure"
			}
		],
		"userPromptSubmit": [
			{
				"command": "caliber learn observe --prompt"
			}
		],
		"sessionEnd": [
			{
				"command": "caliber learn finalize --auto"
			}
		]
	}
}
