{
	"name": "@styleframe/testing-benchmark",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"scripts": {
		"measure": "tsx src/measure.ts",
		"build:styleframe": "tsx src/styleframe/build.ts",
		"build:tailwind": "tsx src/tailwind/build.ts",
		"visual": "tsx src/visual-compare.ts",
		"test:parity": "playwright test",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@styleframe/config-typescript": "workspace:^",
