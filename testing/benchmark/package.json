		"@styleframe/theme": "workspace:^",
		"@tailwindcss/cli": "4.3.1",
		"@tailwindcss/node": "4.3.1",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"playwright": "catalog:",
		"styleframe": "workspace:^",
		"tailwindcss": "catalog:nuxt",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
