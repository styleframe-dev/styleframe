{
	"name": "@styleframe/figma",
	"version": "2.1.0",
	"description": "Figma plugin for syncing Styleframe variables with Figma variables",
	"keywords": [
		"css-variables",
		"design-tokens",
		"figma",
		"styleframe"
	],
	"homepage": "https://github.com/styleframe-dev/styleframe#readme",
	"bugs": {
		"url": "https://github.com/styleframe-dev/styleframe/issues"
	},
	"license": "MIT",
	"author": "Alex Grozav <alex@styleframe.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/styleframe-dev/styleframe.git"
	},
	"files": [
		"dist",
		"manifest.json",
		"LICENSE",
		"CHANGELOG.md",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown && vite build --mode code && vite build",
		"build:lib": "tsdown",
		"build:plugin": "vite build --mode code && vite build",
		"dev": "tsdown -w",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@styleframe/core": "workspace:^3.6.0",
		"@styleframe/dtcg": "workspace:^1.1.0",
		"culori": "^4.0.2"
	},
	"devDependencies": {
		"@figma/plugin-typings": "^1.103.0",
		"@styleframe/config-typescript": "workspace:^3.0.0",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "^0.12.0",
		"typescript": "^5.8.3",
		"vite": "catalog:",
		"vite-plugin-singlefile": "^2.3.3",
		"vitest": "catalog:"
	}
}
