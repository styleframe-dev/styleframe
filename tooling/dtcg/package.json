{
	"name": "@styleframe/dtcg",
	"version": "1.1.0",
	"description": "DTCG (Design Tokens Community Group) format parser, validator, and serializer for Styleframe.",
	"keywords": [
		"design-tokens",
		"dtcg",
		"styleframe",
		"tokens",
		"w3c"
	],
	"homepage": "https://github.com/styleframe-dev/styleframe#readme",
	"bugs": {
		"url": "https://github.com/styleframe-dev/styleframe/issues"
	},
	"license": "MIT",
	"author": "Alex Grozav <alex@styleframe.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/styleframe-dev/styleframe.git"
	},
	"files": [
		"dist",
		"LICENSE",
		"CHANGELOG.md",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown -w",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"culori": "catalog:"
	},
	"devDependencies": {
		"@styleframe/config-typescript": "workspace:^",
		"@types/culori": "^2.1.1",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
