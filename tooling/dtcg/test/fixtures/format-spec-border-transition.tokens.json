{
	"button-border": {
		"$type": "border",
		"$value": {
			"color": { "colorSpace": "srgb", "components": [0.2, 0.2, 0.8] },
			"width": { "value": 2, "unit": "px" },
			"style": "solid"
		}
	},
	"transition-smooth": {
		"$type": "transition",
		"$value": {
			"duration": { "value": 300, "unit": "ms" },
			"delay": { "value": 0, "unit": "ms" },
			"timingFunction": [0.42, 0, 0.58, 1]
		}
	}
}
