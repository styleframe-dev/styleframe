{
	"shadow": {
		"elevation-high": {
			"$type": "shadow",
			"$value": {
				"color": {
					"colorSpace": "srgb",
					"components": [0, 0, 0],
					"alpha": 0.2
				},
				"offsetX": { "value": 0, "unit": "px" },
				"offsetY": { "value": 4, "unit": "px" },
				"blur": { "value": 12, "unit": "px" }
			}
		},
		"stack": {
			"$type": "shadow",
			"$value": [
				{
					"color": {
						"colorSpace": "srgb",
						"components": [0, 0, 0],
						"alpha": 0.05
					},
					"offsetX": { "value": 0, "unit": "px" },
					"offsetY": { "value": 1, "unit": "px" }
				},
				{
					"color": {
						"colorSpace": "srgb",
						"components": [0, 0, 0],
						"alpha": 0.1
					},
					"offsetX": { "value": 0, "unit": "px" },
					"offsetY": { "value": 4, "unit": "px" },
					"blur": { "value": 8, "unit": "px" }
				}
			]
		}
	}
}
