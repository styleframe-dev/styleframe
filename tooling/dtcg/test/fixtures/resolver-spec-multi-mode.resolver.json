{
	"$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
	"version": "2025.10",
	"sets": {
		"foundation": {
			"sources": [{ "$ref": "foundation.json" }]
		}
	},
	"modifiers": {
		"theme": {
			"description": "Color theme",
			"contexts": {
				"light": [{ "$ref": "themes/light.json" }],
				"dark": [{ "$ref": "themes/dark.json" }]
			},
			"default": "light"
		}
	},
	"resolutionOrder": [
		{ "$ref": "#/sets/foundation" },
		{ "$ref": "#/modifiers/theme" }
	]
}
