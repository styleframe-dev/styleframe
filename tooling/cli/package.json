{
	"name": "@styleframe/cli",
	"version": "4.1.1",
	"description": "A command-line interface for styleframe.",
	"homepage": "https://github.com/styleframe-dev/styleframe#readme",
	"bugs": {
		"url": "https://github.com/styleframe-dev/styleframe/issues"
	},
	"author": "Alex Grozav <alex@styleframe.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/styleframe-dev/styleframe.git"
	},
	"files": [
		"dist",
		"LICENSE",
		"CHANGELOG.md",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "pnpm typecheck && vite build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"test:dev": "vitest --watch",
		"playground:init": "tsx playground/init.ts",
		"playground:build": "tsx playground/build.ts"
	},
	"dependencies": {
		"@styleframe/dtcg": "workspace:^",
		"@styleframe/figma": "workspace:^",
		"citty": "^0.2.2",
		"consola": "catalog:",
		"magicast": "^0.5.3"
	},
	"devDependencies": {
		"@microsoft/api-extractor": "catalog:",
		"@styleframe/config-typescript": "workspace:^3.0.0",
		"@styleframe/config-vite": "workspace:^3.1.0",
		"@styleframe/core": "workspace:^3.6.1",
		"@styleframe/license": "catalog:",
		"@styleframe/loader": "workspace:^3.0.3",
		"@styleframe/theme": "workspace:^3.8.0",
		"@vitest/coverage-v8": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "catalog:",
		"vite-plugin-node": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@styleframe/loader": "workspace:^3.0.3"
	}
}
